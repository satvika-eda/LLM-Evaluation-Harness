# LLM Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
HUGGINGFACE_API_KEY=hf_...

# Database (docker-compose composes DATABASE_URL from POSTGRES_* itself;
# DATABASE_URL here is for running the API/worker outside Docker)
POSTGRES_USER=llm_eval
POSTGRES_PASSWORD=llm_eval
POSTGRES_DB=llm_eval
DATABASE_URL=postgresql://llm_eval:llm_eval@localhost:5432/llm_eval

# Cache
REDIS_URL=redis://localhost:6379/0
# How long cached generations live (seconds). Default 7 days — long enough to
# survive a run split across days by a judge daily-quota limit. Keys are
# content-addressed, so a long TTL can never serve a wrong answer.
CACHE_TTL_SECONDS=604800

# Dashboard → API base URL
FASTAPI_URL=http://localhost:8000

# Logging
LOG_LEVEL=INFO

# ── LLM judge (RAGAS / DeepEval scorers) ─────────────────────────────────────
# Independent of the open-weight models being benchmarked. gpt-4o-mini is
# ~15x cheaper per token than gpt-4o with a much higher daily token budget —
# use it unless you have a specific reason not to. RAGAS embeddings stay on
# OpenAI regardless.
LLM_JUDGE_MODEL=gpt-4o-mini
# JUDGE_BASE_URL=https://router.huggingface.co/v1
# JUDGE_API_KEY=
# Max concurrent judge LLM calls per scorer — caps RAGAS/DeepEval fan-out so
# runs stay under the OpenAI tokens-per-minute ceiling. 2 is safe for tier 1.
JUDGE_MAX_CONCURRENCY=2
# Responses scored per chunk (commit checkpoint + memory bound). 10 keeps the
# BERTScore working set and judge bursts small on low-RAM hosts.
SCORING_CHUNK_SIZE=10

# ── BERTScore embedding model ────────────────────────────────────────────────
# roberta-large (~1.4 GB RAM) fits an 8 GB host; the higher-quality default
# microsoft/deberta-xlarge-mnli needs ~3.5 GB. Scores are NOT comparable
# across embedding models — pick one per benchmark and keep it.
BERTSCORE_MODEL=roberta-large
