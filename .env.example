# LLM Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
HUGGINGFACE_API_KEY=hf_...

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/llm_eval

# Cache
REDIS_URL=redis://localhost:6379/0

# Optional: evaluation settings
EVAL_BATCH_SIZE=10
EVAL_MAX_CONCURRENCY=5
LOG_LEVEL=INFO

# Optional: LLM judge used by the RAGAS / DeepEval scorers (independent of the
# open-weight models being benchmarked). Defaults to GPT-4o via OpenAI. Swap to
# a cheaper / higher-rate-limit model (e.g. gpt-4o-mini) or an OpenAI-compatible
# endpoint to dodge the OpenAI TPM wall on larger runs. RAGAS embeddings stay on
# OpenAI regardless.
LLM_JUDGE_MODEL=gpt-4o
# JUDGE_BASE_URL=https://router.huggingface.co/v1
# JUDGE_API_KEY=
# Max concurrent judge LLM calls per scorer — caps RAGAS/DeepEval fan-out so
# large runs stay under the OpenAI tokens-per-minute ceiling (default 4).
JUDGE_MAX_CONCURRENCY=4
